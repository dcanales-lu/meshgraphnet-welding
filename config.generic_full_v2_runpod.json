{
  "data_root": "data",
  "checkpoint_dir": "checkpoints_genfull_v2",
  "log_dir": "logs",
  "rollout_pred_dir": "data/output/rollout_pred_genfull_v2",
  "num_export_sims": 2,

  "epochs": 100,
  "batch_size": 16,
  "lr": 0.001,
  "weight_decay": 0.0001,
  "grad_clip": 1.0,
  "scheduler": "plateau",
  "early_stop_patience": 30,
  "early_stop_min_delta": 0.01,
  "resume": false,

  "noise_std": 5.0,
  "noise_beta": 0.0,
  "noise_floor": 0.0,
  "pushforward_steps": 1,
  "max_windows_per_epoch": 0,
  "max_val_sims": 20,

  "hidden_dim": 128,
  "num_processing_steps": 8,
  "num_mlp_layers": 2,
  "activation": "relu",
  "use_layer_norm": true,
  "aggregation": "sum",
  "use_generic": true,
  "generic_mode": "full",

  "val_fraction": 0.20,
  "test_fraction": 0.00,
  "split_seed": 0,
  "val_every": 5,
  "checkpoint_every": 10,
  "num_workers": 16,
  "seed": 0,
  "device": "auto",
  "progress_bar": false
}
