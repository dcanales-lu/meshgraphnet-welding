# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# uv
# (uv.lock IS committed; only ignore caches)
.uv/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# LaTeX build artifacts (docs/ .tex + .pdf ARE committed; these are regenerable)
*.aux
*.toc
*.out
*.nav
*.snm
*.synctex.gz
*.fls
*.fdb_latexmk

# Project data artifacts (generated FEM datasets, graphs, checkpoints, logs)
data/raw/
data/processed/
*.npz
*.npy
*.vtk
*.vtu
*.xdmf
*.h5
checkpoints/
checkpoints_*/
runs/
wandb/
*.pt
*.pth

# Training logs (machine-specific, regenerable; kept on disk, not in git)
logs/
*.log

# Generated output artifacts (rollout exports, videos, CSV/PNG analyses) — large
# and regenerable; not needed on the training pod.
data/output/
*.mp4
*.mp3

# Training dataset (.npz) is NOT committed: the v2 corpus is ~6.8 GB (too large
# for git/GitHub) and is fully reproducible from the seeded generator. Regenerate
# with:
#   uv run python -m src.simulation.generate_dataset --num_train 300 --num_val 60 --workers 11
# (data/raw/ and *.npz are already ignored above.)
